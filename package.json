{
  "name": "mystack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@elysiajs/cors": "^1.4.1",
      "@elysiajs/eden": "^1.4.8",
      "@elysiajs/openapi": "^1.4.14",
      "@types/bun": "^1.3.11",
      "@types/react-dom": "^19.2.3",
      "dotenv": "^17.2.2",
      "drizzle-orm": "^1.0.0-beta.19",
      "drizzle-kit": "^1.0.0-beta.19",
      "elysia": "^1.4.28",
      "lucide-react": "^1.6.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.2.2",
      "typescript": "^6.0.2",
      "vite-plus": "^0.1.14",
      "vitest": "^4.1.1",
      "zod": "^4.1.13"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "clean_installation": "find . -type d -name 'node_modules' -prune -exec rm -rf '{}' +",
    "db:generate": "turbo -F @mystack/db db:generate",
    "db:migrate": "turbo -F @mystack/db db:migrate",
    "db:push": "turbo -F @mystack/db db:push",
    "db:studio": "turbo -F @mystack/db db:studio",
    "dev": "turbo dev",
    "dev:native": "turbo -F native dev",
    "dev:server": "turbo -F server dev",
    "dev:web": "turbo -F web dev",
    "fmt": "vp fmt",
    "knip": "knip",
    "lint": "turbo run lint:vp lint:eslint lint:biome",
    "lint:biome": "biome check --diagnostic-level=error",
    "lint:biome:fix": "biome lint --fix",
    "lint:eslint": "eslint --cache --cache-location node_modules/.cache/.eslintcache/ .",
    "lint:eslint:fix": "eslint --cache --cache-location node_modules/.cache/.eslintcache/ . --fix --fix-type problem",
    "lint:fix": "turbo run lint:eslint:fix lint:biome:fix lint:oxfmt:fix",
    "lint:vp": "vp check -- --threads=2",
    "openapi:generate": "turbo -F @mystack/api openapi:generate",
    "openapi:generate:client": "turbo -F @mystack/api openapi:generate:client",
    "prepare": "vp config",
    "ready": "bun run lint && vp test",
    "test": "vp test",
    "update-deps": "bun update -i -r"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@mystack/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/ms": "^2.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/utils": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-biome": "^2.1.3",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "ioredis-mock": "^8.13.1",
    "knip": "^6.0.4",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite-plus": "catalog:",
    "vitest": "^4.1.1"
  },
  "packageManager": "bun@1.3.10"
}
