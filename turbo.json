{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "//#lint:vp": {},
    "//#lint:eslint": {},
    "//#lint:biome": {},
    "//#lint:eslint:fix": {},
    "//#lint:biome:fix": {},
    "//#lint:oxfmt:fix": {},
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "openapi:generate": {
      "inputs": ["src/**", "package.json"],
      "outputs": ["openapi/openapi.json"]
    },
    "openapi:generate:client": {
      "dependsOn": ["openapi:generate"],
      "inputs": ["openapi/openapi.json", "openapitools.json"],
      "outputs": ["openapi/generated/**"]
    }
  }
}
